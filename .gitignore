# Environment
.env

# Storage (uploads, logs, cache — not committed)
storage/logs/*
storage/cache/*
storage/uploads/*
storage/certificates/*
!storage/logs/.gitkeep
!storage/cache/.gitkeep
!storage/uploads/.gitkeep
!storage/certificates/.gitkeep

