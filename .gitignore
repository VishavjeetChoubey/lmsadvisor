public/assets/vendor/sortablejs/
public/assets/vendor/quill/
public/assets/vendor/chartjs/
public/assets/vendor/plyr/
public/assets/vendor/tom-select/
public/assets/vendor/fullcalendar/

# Uploaded assets (runtime)
public/assets/uploads/

# mPDF cache (Phase 12)
app/Vendor/mpdf/

