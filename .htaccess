Options -MultiViews -Indexes
RewriteEngine On

# ── Pass Authorization header to PHP (Apache strips it by default) ────────────
RewriteCond %{HTTP:Authorization} .
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# ── Also handle CGI/FastCGI environments ─────────────────────────────────────
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# ── Allow direct access to real files (CSS, JS, images, fonts) ───────────────
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ── Allow direct access to real directories ───────────────────────────────────
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ── Send everything else through the front controller ────────────────────────
RewriteRule ^ index.php [L,QSA]
